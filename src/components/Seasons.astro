---
import ChapterReveal from "./ChapterReveal";
import Picture from "./Picture.astro";
import { getCopy } from "~/content/copy";
import type { Locale } from "~/i18n/config";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const { seasons } = getCopy(locale);
---

<section id="seasons" class="relative">
  <div class="chapter chapter--dense">
    <div class="chapter__inner">
      <ChapterReveal client:visible stagger as="header" className="max-w-[64ch]">
        <p data-reveal-child class="eyebrow">
          <span class="chapter-index mr-4">{seasons.index}</span>
          {seasons.eyebrow}
        </p>
        <h2 data-reveal-child class="display mt-4">{seasons.title}</h2>
        <hr data-reveal-child class="rule-gold" />
        <p data-reveal-child class="lede">{seasons.intro}</p>
        <p data-reveal-child class="eyebrow mt-6 text-[var(--color-bone-soft)]/70">{seasons.minimum_stay}</p>
      </ChapterReveal>
    </div>
  </div>

  <ol class="seasons-grid grid md:grid-cols-2">
    {seasons.items.map((s, i) => (
      <li class="season relative h-[56vh] md:h-[70vh] overflow-hidden bg-[var(--color-ink)]">
        <div class="absolute inset-0">
          <Picture src={s.image} alt={s.label} sizes="(min-width: 768px) 50vw, 100vw" />
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-black/10"></div>
        <div class="absolute inset-0 flex flex-col justify-end p-6 sm:p-10 md:p-14">
          <p class="chapter-index">{String(i + 1).padStart(2, "0")}</p>
          <p class="eyebrow mt-2">{s.window}</p>
          <h3 class="mt-2 md:mt-3 font-[family-name:var(--font-display)] text-4xl md:text-6xl font-normal leading-none">{s.label}</h3>
          <p class="mt-3 md:mt-4 text-sm md:text-base leading-relaxed text-[var(--color-bone-soft)] max-w-[36ch]">{s.note}</p>
          <p class="mt-4 md:mt-6 font-[family-name:var(--font-display)] italic text-base md:text-xl text-[var(--color-gold)]">{s.price}</p>
        </div>
      </li>
    ))}
  </ol>
</section>
