---
import ChapterReveal from "./ChapterReveal";
import Picture from "./Picture.astro";
import { getCopy } from "~/content/copy";
import type { Locale } from "~/i18n/config";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const { the_building, signature } = getCopy(locale);
---

<section id="the-building" class="chapter">
  <div class="chapter__inner">
    <ChapterReveal client:visible stagger as="header" className="mb-10 max-w-[72ch]">
      <p data-reveal-child class="eyebrow">
        <span class="chapter-index mr-4">{the_building.index}</span>
        {the_building.eyebrow}
      </p>
      <h2 data-reveal-child class="display mt-4">{the_building.title}</h2>
      <p data-reveal-child class="mt-2 font-[family-name:var(--font-display)] italic text-xl md:text-2xl text-[var(--color-gold)]">{the_building.subtitle}</p>
      <hr data-reveal-child class="rule-gold" />
    </ChapterReveal>

    <div class="grid gap-10 md:grid-cols-[1fr_1.1fr] lg:gap-16 items-start">
      <ChapterReveal client:visible stagger as="div">
        <p data-reveal-child class="drop-cap text-base md:text-lg leading-relaxed text-[var(--color-bone-soft)] max-w-[52ch]">
          {the_building.body_1}
        </p>
        <p data-reveal-child class="mt-6 text-base md:text-lg leading-relaxed text-[var(--color-bone-soft)] max-w-[52ch]">
          {the_building.body_2}
        </p>
        <p data-reveal-child class="mt-6 text-base md:text-lg leading-relaxed text-[var(--color-bone-soft)] max-w-[52ch]">
          {the_building.body_3}
        </p>
        <p data-reveal-child class="pull-quote mt-10 max-w-[32ch]">{the_building.quote}</p>
      </ChapterReveal>

      <ChapterReveal client:visible as="div" y={30}>
        <div class="building-grid grid grid-cols-2 gap-2">
          <div class="col-span-2 aspect-[16/10] overflow-hidden bg-[var(--color-ink-soft)]">
            <Picture src="building-facade" alt="L'Arbois · façade courbe, 1933" sizes="(min-width: 768px) 50vw, 100vw" />
          </div>
          <div class="aspect-[4/5] overflow-hidden bg-[var(--color-ink-soft)]">
            <Picture src="building-exterior" alt="L'Arbois · depuis la rue" sizes="(min-width: 768px) 25vw, 50vw" />
          </div>
          <div class="aspect-[4/5] overflow-hidden bg-[var(--color-ink-soft)]">
            <Picture src="building-stairs" alt="Hall de granit & damier" sizes="(min-width: 768px) 25vw, 50vw" />
          </div>
        </div>

        <ul class="mt-6 space-y-3 text-sm text-[var(--color-bone-soft)]">
          <li class="flex items-start gap-3 border-t border-[var(--color-gold)]/20 pt-3">
            <span class="chapter-index flex-shrink-0">·</span>
            <span>{the_building.labels.architect}</span>
          </li>
          <li class="flex items-start gap-3 border-t border-[var(--color-gold)]/20 pt-3">
            <span class="chapter-index flex-shrink-0">·</span>
            <span>{the_building.labels.twin}</span>
          </li>
          <li class="flex items-start gap-3 border-t border-[var(--color-gold)]/20 pt-3">
            <span class="chapter-index flex-shrink-0">·</span>
            <span>{the_building.labels.listed}</span>
          </li>
        </ul>
      </ChapterReveal>
    </div>

    <ChapterReveal client:visible stagger as="ol" className="mt-12 md:mt-16 grid gap-0 md:gap-6 md:grid-cols-4 border-t border-[var(--color-gold)]/20">
      {the_building.timeline.map((t, i) => (
        <li data-reveal-child class={`timeline-item py-5 md:py-0 md:pt-8 ${i > 0 ? "border-t border-[var(--color-gold)]/10 md:border-t-0" : ""}`}>
          <p class="chapter-index">{t.year}</p>
          <p class="mt-2 font-[family-name:var(--font-display)] text-lg md:text-xl leading-snug">{t.label}</p>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-bone-soft)]/80">{t.detail}</p>
        </li>
      ))}
    </ChapterReveal>

    <p class="signature mt-10 text-right">{signature}</p>
  </div>
</section>
