---
import ChapterReveal from "./ChapterReveal";
import ConciergeForm from "./ConciergeForm";
import Picture from "./Picture.astro";
import { t } from "~/i18n/ui";
import type { Locale } from "~/i18n/config";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const strings = t(locale).concierge;
---

<section id="concierge" class="concierge relative overflow-hidden">
  <div class="absolute inset-0" aria-hidden="true">
    <Picture src="salon-view" alt="" sizes="100vw" />
    <div class="absolute inset-0 bg-[var(--color-ink)]/85 backdrop-blur-[3px]"></div>
  </div>

  <div class="relative z-10 w-full px-[var(--gutter)] py-24 md:py-32">
    <div class="mx-auto max-w-[var(--content-max)]">
      <div class="grid gap-14 lg:grid-cols-[1fr_1.2fr] lg:gap-24 items-start">
        <ChapterReveal client:visible stagger as="div">
          <p data-reveal-child class="eyebrow">{strings.title}</p>
          <h2 data-reveal-child class="display mt-3">{strings.subtitle}</h2>
          <hr data-reveal-child class="rule-gold" />
          <p data-reveal-child class="text-sm leading-relaxed text-[var(--color-bone-soft)] max-w-[36ch]">
            Notre conciergerie privée répond sous vingt-quatre heures, avec discrétion. Un interlocuteur unique, de la pré-réservation au départ.
          </p>
          <p data-reveal-child class="pull-quote mt-8">Une semaine à nous, une adresse à vous.</p>
        </ChapterReveal>

        <ChapterReveal client:visible as="div" y={40} className="bg-[var(--color-ink-soft)]/80 border border-[var(--color-gold)]/20 p-8 md:p-10 backdrop-blur-sm">
          <ConciergeForm client:visible locale={locale} />
        </ChapterReveal>
      </div>
    </div>
  </div>
</section>
