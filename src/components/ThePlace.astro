---
import ChapterReveal from "./ChapterReveal";
import ClipReveal from "./ClipReveal";
import { getCopy } from "~/content/copy";
import type { Locale } from "~/i18n/config";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const { the_place } = getCopy(locale);
---

<section id="the-place" class="chapter">
  <div class="chapter__inner">
    <div class="grid gap-10 md:grid-cols-[1fr_1fr] md:gap-16 items-center">
      <ChapterReveal client:visible stagger as="div">
        <p data-reveal-child class="eyebrow">
          <span class="chapter-index mr-4">{the_place.index}</span>
          {the_place.eyebrow}
        </p>
        <h2 data-reveal-child class="display mt-4 max-w-[16ch]">{the_place.title}</h2>
        <hr data-reveal-child class="rule-gold" />
        <p data-reveal-child class="lede max-w-[44ch]">{the_place.body}</p>
        <p data-reveal-child class="eyebrow mt-6">{the_place.coordinates}</p>

        <ul data-reveal-child class="mt-8 space-y-3 text-sm">
          <li class="flex items-center gap-3">
            <span class="inline-block h-2 w-2 rounded-full bg-[var(--color-gold)] ring-4 ring-[var(--color-gold)]/20"></span>
            <span class="text-[var(--color-bone-soft)]">{the_place.landmarks.villa}</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="inline-block h-2 w-2 rounded-full bg-[var(--color-gold-soft)]/70"></span>
            <span class="text-[var(--color-bone-soft)]">{the_place.landmarks.dock}</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="inline-block h-2 w-2 rounded-full border border-[var(--color-gold)]"></span>
            <span class="text-[var(--color-bone-soft)]">{the_place.landmarks.twin}</span>
          </li>
        </ul>
      </ChapterReveal>

      <ClipReveal client:visible direction="left" className="place-map">
        <div class="relative w-full aspect-[4/5] max-w-[36rem] mx-auto">
          <svg viewBox="0 0 400 500" class="w-full h-full block" role="img" aria-label="Carte du Golfe de Saint-Tropez : Sainte-Maxime et L’Arbois au nord, Latitude 43 et Saint-Tropez au sud">
            <defs>
              <linearGradient id="sea" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#0e1e33" />
                <stop offset="100%" stop-color="#050a14" />
              </linearGradient>
              <linearGradient id="land" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#c9a97a" stop-opacity="0.32" />
                <stop offset="100%" stop-color="#b8935a" stop-opacity="0.08" />
              </linearGradient>
              <radialGradient id="glow" cx="0.5" cy="0.5" r="0.5">
                <stop offset="0%" stop-color="#b8935a" stop-opacity="0.6" />
                <stop offset="60%" stop-color="#b8935a" stop-opacity="0.1" />
                <stop offset="100%" stop-color="#b8935a" stop-opacity="0" />
              </radialGradient>
            </defs>

            <!-- Sea -->
            <rect width="400" height="500" fill="url(#sea)" />

            <!-- Subtle water ripples -->
            <g stroke="#b8935a" stroke-opacity="0.06" stroke-width="0.4" fill="none">
              <path d="M0,220 Q100,215 200,220 T400,220" />
              <path d="M0,260 Q100,255 200,260 T400,260" />
              <path d="M0,300 Q100,295 200,300 T400,300" />
            </g>

            <!-- Côte réelle OpenStreetMap, projection equirectangulaire cos(43°N) -->
            <path
              d="M 302.6,495.3 L 298.2,487.9 L 302.5,484.0 L 298.4,480.5 L 295.7,481.8 L 294.7,480.4 L 295.6,479.3 L 292.7,479.7 L 289.8,476.1 L 285.8,457.9 L 284.3,423.1 L 288.2,376.5 L 293.2,362.1 L 299.9,355.1 L 305.2,353.7 L 317.5,358.6 L 321.0,358.3 L 327.4,348.3 L 331.8,344.3 L 334.4,345.1 L 338.1,337.8 L 339.7,338.4 L 345.9,333.7 L 356.7,332.8 L 359.3,330.3 L 357.3,325.0 L 358.4,315.5 L 361.1,313.8 L 363.4,302.9 L 367.1,298.6 L 371.4,297.9 L 371.5,293.6 L 374.2,291.0 L 374.4,287.0 L 376.2,280.5 L 375.0,280.0 L 368.7,278.1 L 354.3,259.1 L 346.8,256.0 L 344.8,256.9 L 342.2,254.6 L 340.4,255.4 L 338.4,252.0 L 336.5,252.0 L 330.1,241.0 L 326.5,240.9 L 327.3,237.9 L 325.5,235.5 L 322.7,238.2 L 319.3,237.2 L 315.2,241.0 L 308.2,242.1 L 305.7,245.0 L 302.1,245.8 L 303.5,249.7 L 302.3,254.6 L 303.2,259.1 L 302.1,261.5 L 303.2,272.5 L 299.7,279.0 L 290.9,286.1 L 286.2,286.4 L 269.6,276.5 L 268.5,273.4 L 262.1,267.3 L 259.0,266.0 L 253.1,266.9 L 249.5,264.3 L 248.6,265.5 L 246.2,264.8 L 246.2,260.5 L 241.9,253.9 L 230.1,253.1 L 229.7,255.4 L 227.4,253.4 L 225.2,254.8 L 222.8,253.0 L 207.4,257.4 L 206.9,258.8 L 222.5,254.6 L 223.0,255.7 L 222.5,262.4 L 219.8,263.2 L 216.6,257.5 L 210.6,267.2 L 206.6,265.1 L 208.4,259.6 L 206.0,265.3 L 208.9,267.1 L 207.9,269.1 L 200.0,274.5 L 200.6,275.7 L 197.2,277.8 L 190.3,278.6 L 187.0,277.4 L 187.3,279.7 L 183.6,284.2 L 175.9,288.6 L 167.9,288.2 L 161.8,290.0 L 155.4,287.7 L 150.8,288.0 L 148.7,290.3 L 134.8,292.0 L 130.7,295.0 L 118.7,290.4 L 115.0,291.4 L 112.1,294.6 L 107.9,295.3 L 103.4,294.5 L 98.0,290.2 L 98.9,282.2 L 96.6,273.5 L 93.7,274.7 L 91.4,268.4 L 90.0,268.7 L 88.1,268.3 L 87.2,269.9 L 85.5,268.6 L 85.0,262.5 L 90.1,262.5 L 90.5,261.3 L 83.0,257.8 L 80.9,249.0 L 81.2,239.2 L 82.7,239.6 L 86.0,231.4 L 89.9,227.7 L 91.2,228.5 L 93.4,225.2 L 94.5,226.1 L 96.7,222.9 L 101.6,222.4 L 110.1,216.6 L 111.3,216.5 L 112.3,218.9 L 114.8,216.5 L 116.8,217.4 L 124.1,214.5 L 126.3,208.8 L 129.4,207.6 L 130.4,209.3 L 134.1,204.2 L 144.3,198.0 L 146.1,194.1 L 147.8,195.0 L 148.7,191.6 L 156.2,188.9 L 162.0,181.3 L 166.7,179.1 L 167.5,180.8 L 175.9,174.4 L 181.4,173.2 L 185.5,175.7 L 188.5,166.9 L 190.5,167.2 L 188.6,166.1 L 189.0,160.8 L 190.6,155.2 L 193.1,155.0 L 191.7,153.6 L 193.4,147.9 L 194.9,146.1 L 196.8,146.6 L 199.6,142.9 L 204.4,143.6 L 209.5,136.1 L 218.2,133.7 L 220.5,138.4 L 220.1,134.8 L 223.1,132.9 L 226.6,136.4 L 222.5,138.8 L 223.2,139.9 L 227.4,137.3 L 231.8,140.8 L 229.3,142.1 L 219.2,141.3 L 230.0,142.8 L 232.7,141.1 L 233.0,139.2 L 238.1,138.8 L 242.5,136.5 L 251.3,130.3 L 254.7,125.7 L 276.3,111.0 L 282.9,110.0 L 299.1,116.8 L 306.1,114.3 L 307.5,115.8 L 310.5,112.2 L 311.6,109.7 L 303.9,109.5 L 303.2,106.9 L 301.2,106.5 L 299.7,102.4 L 293.7,96.2 L 291.4,82.1 L 291.5,71.9 L 296.4,68.0 L 298.6,63.5 L 302.8,41.2 L 308.2,36.4 L 310.5,31.5 L 319.1,25.8 L 322.4,25.6 L 330.8,15.8 L 335.8,14.0 L 338.8,14.8 L 338.7,17.1 L 341.7,15.2 L 343.5,18.2 L 343.1,15.2 L 348.8,13.4 L 349.7,16.8 L 343.9,20.3 L 350.0,17.7 L 348.9,12.2 L 353.8,10.1 L 357.8,13.3 L 361.5,13.4 L 362.0,11.9 L 365.4,12.8 L 367.4,14.9 L 365.7,16.5 L 367.2,18.6 L 370.1,17.3 L 369.3,16.7 L 372.0,13.4 L 375.9,12.6 L 375.2,11.5 L 379.7,6.3 L 387.6,4.7 L 390.1,2.4 L 394.6,3.9 L 398.1,2.2 L 398.1,0 L 0,0 L 0,500 L 302.6,500 Z"
              fill="url(#land)"
              stroke="#b8935a"
              stroke-opacity="0.7"
              stroke-width="0.6"
              stroke-linejoin="round"
            />
            <text x="100" y="100" fill="#c9a97a" font-size="10" letter-spacing="5" font-family="Satoshi, sans-serif" opacity="0.55">SAINTE-MAXIME</text>
            <text x="345" y="50" fill="#c9a97a" font-size="6" letter-spacing="2" font-family="Satoshi, sans-serif" opacity="0.6">CAP DES SARDINAUX</text>
            <text x="180" y="320" fill="#c9a97a" font-size="10" letter-spacing="5" font-family="Satoshi, sans-serif" opacity="0.55">SAINT-TROPEZ</text>

            <!-- Boat route animated : L'Arbois (234, 127) -> port St-Tropez (220, 260) -->
            <path
              class="boat-path"
              d="M234,135 Q245,195 220,260"
              stroke="#b8935a"
              stroke-opacity="0.7"
              stroke-width="1"
              fill="none"
              stroke-dasharray="3 5"
            />

            <!-- L'Arbois — main marker (24 av Gén Leclerc, 43.3093°N, 6.6432°E) -->
            <g class="marker marker--primary">
              <circle class="marker__ring-far" cx="234" cy="127" r="36" fill="none" stroke="#b8935a" stroke-opacity="0.15" />
              <circle class="marker__ring-mid" cx="234" cy="127" r="20" fill="none" stroke="#b8935a" stroke-opacity="0.35" />
              <circle class="marker__pulse" cx="234" cy="127" r="8" fill="url(#glow)" />
              <circle cx="234" cy="127" r="5" fill="#b8935a" />
              <circle cx="234" cy="127" r="2" fill="#f7f5f0" />
            </g>
            <text x="246" y="123" fill="#c9a97a" font-size="11" letter-spacing="3" font-family="Gambarino, Fraunces, serif" font-style="italic">L’Arbois</text>
            <text x="246" y="137" fill="#c9a97a" font-size="7" letter-spacing="3" font-family="Satoshi, sans-serif" opacity="0.7">SAINTE-MAXIME · 1933</text>

            <!-- Jetée Olivier Bausset (Bateaux Verts) — 215, 131 -->
            <g class="marker marker--dock">
              <line x1="215" y1="138" x2="215" y2="152" stroke="#c9a97a" stroke-opacity="0.7" stroke-width="1" />
              <circle cx="215" cy="152" r="2.5" fill="#c9a97a" opacity="0.75" />
            </g>
            <text x="120" y="162" fill="#c9a97a" font-size="7" letter-spacing="3" font-family="Satoshi, sans-serif" opacity="0.7">JETÉE OLIVIER BAUSSET · BATEAUX VERTS</text>

            <!-- Latitude 43 (le jumeau) — Saint-Tropez (195, 281) -->
            <g class="marker marker--twin">
              <circle cx="195" cy="281" r="4" fill="none" stroke="#c9a97a" stroke-width="1.2" />
              <circle cx="195" cy="281" r="1.5" fill="#c9a97a" opacity="0.8" />
            </g>
            <text x="135" y="295" fill="#c9a97a" font-size="9" letter-spacing="3" font-family="Gambarino, Fraunces, serif" font-style="italic" opacity="0.9">Latitude 43</text>
            <text x="135" y="307" fill="#c9a97a" font-size="7" letter-spacing="3" font-family="Satoshi, sans-serif" opacity="0.6">PINGUSSON · 1932</text>

            <!-- Boat travel time -->
            <g transform="translate(258, 195)">
              <text x="0" y="0" fill="#c9a97a" font-size="7" letter-spacing="4" font-family="Satoshi, sans-serif" opacity="0.7">15′ · BATEAU</text>
            </g>

            <!-- Compass -->
            <g transform="translate(365, 45)">
              <line x1="0" y1="-18" x2="0" y2="18" stroke="#b8935a" stroke-width="0.6" stroke-opacity="0.6" />
              <polygon points="0,-22 -4,-12 4,-12" fill="#b8935a" opacity="0.8" />
              <text x="0" y="-26" fill="#c9a97a" font-size="9" text-anchor="middle" letter-spacing="2">N</text>
            </g>

            <!-- Bottom caption -->
            <text x="200" y="492" fill="#f7f5f0" opacity="0.3" font-size="7" text-anchor="middle" letter-spacing="4" font-family="Satoshi, sans-serif">GOLFE DE SAINT-TROPEZ · 43.31°N</text>

            <!-- Subtle grid -->
            <g stroke="#f7f5f0" stroke-opacity="0.04" stroke-width="0.4">
              <line x1="0" y1="250" x2="400" y2="250" />
              <line x1="200" y1="0" x2="200" y2="500" />
            </g>
          </svg>
        </div>
      </ClipReveal>
    </div>
  </div>
</section>

<style>
  .place-map {
    transform-origin: center center;
  }
  .marker__ring-far {
    animation: ring-pulse 4s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  .marker__ring-mid {
    animation: ring-pulse 4s ease-in-out infinite;
    animation-delay: 0.6s;
    transform-box: fill-box;
    transform-origin: center;
  }
  .marker__pulse {
    animation: pulse-glow 3.5s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  @keyframes ring-pulse {
    0% { transform: scale(0.55); opacity: 0.7; }
    100% { transform: scale(1.1); opacity: 0; }
  }
  @keyframes pulse-glow {
    0%, 100% { opacity: 0.45; transform: scale(0.85); }
    50% { opacity: 1; transform: scale(1.15); }
  }
  .boat-path {
    stroke-dasharray: 3 5;
    animation: boat-flow 6s linear infinite;
  }
  @keyframes boat-flow {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -64; }
  }
  @media (prefers-reduced-motion: reduce) {
    .marker__ring-far,
    .marker__ring-mid,
    .marker__pulse,
    .boat-path {
      animation: none !important;
    }
  }
</style>
