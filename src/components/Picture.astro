---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { getImageMeta } from "~/content/images";

interface Props {
  src: string;
  alt: string;
  aspect?: string;
  eager?: boolean;
  class?: string;
  sizes?: string;
  widths?: number[];
  fit?: "cover" | "contain";
  position?: string;
}

const {
  src,
  alt,
  aspect,
  eager = false,
  class: className,
  sizes = "(min-width: 1024px) 1600px, 100vw",
  widths = [640, 1024, 1600, 2400],
  fit = "cover",
  position,
} = Astro.props;

const meta = getImageMeta(src);
const finalAspect = aspect ?? meta.aspect;
const finalPosition = position ?? meta.objectPosition;

const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/images/*.{jpg,jpeg,png}");
const path = `/src/assets/images/${src}.jpg`;
const loader = images[path];

let image: ImageMetadata | null = null;
if (loader) {
  const mod = await loader();
  image = mod.default;
}

const styleParts: string[] = [];
if (finalAspect) styleParts.push(`aspect-ratio: ${finalAspect}`);
styleParts.push(`object-fit: ${fit}`);
styleParts.push(`object-position: ${finalPosition}`);
styleParts.push("width: 100%");
styleParts.push("height: 100%");
const style = styleParts.join("; ");
---

{image ? (
  <Image
    src={image}
    alt={alt}
    widths={widths}
    sizes={sizes}
    formats={["avif", "webp"]}
    loading={eager ? "eager" : "lazy"}
    decoding="async"
    class={className}
    style={style}
  />
) : (
  <div
    class:list={[className, "bg-gradient-to-br from-[var(--color-navy)] to-[var(--color-ink)]"]}
    style={finalAspect ? `aspect-ratio: ${finalAspect}; width: 100%; height: 100%;` : "width: 100%; height: 100%;"}
    role="img"
    aria-label={alt}
  ></div>
)}
