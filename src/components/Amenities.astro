---
import Chapter from "./Chapter.astro";
import ChapterReveal from "./ChapterReveal";
import { getCopy } from "~/content/copy";
import type { Locale } from "~/i18n/config";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const { amenities } = getCopy(locale);
---

<Chapter id="amenities" index={amenities.index} eyebrow={amenities.eyebrow} tone="deep">
  <ChapterReveal client:visible stagger as="header" className="mb-14 max-w-[62ch]">
    <h2 data-reveal-child class="display">{amenities.title}</h2>
    <hr data-reveal-child class="rule-gold" />
    <p data-reveal-child class="lede">{amenities.intro}</p>
  </ChapterReveal>

  <div class="grid gap-10 lg:grid-cols-[1fr_2fr] lg:gap-16">
    <div class="space-y-8">
      <div>
        <p class="eyebrow mb-3">Capacité</p>
        <div class="space-y-1">
          <p class="font-[family-name:var(--font-display)] text-3xl">{amenities.capacity.rooms}</p>
          <p class="font-[family-name:var(--font-display)] text-3xl">{amenities.capacity.guests}</p>
          <p class="text-sm text-[var(--color-bone-soft)] mt-3">{amenities.capacity.beds}</p>
        </div>
      </div>

      <div>
        <p class="eyebrow mb-3">Compris</p>
        <ul class="space-y-2 text-sm text-[var(--color-bone-soft)]">
          {amenities.services_included.map((s) => (
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-gold)] mt-1">·</span>
              <span>{s}</span>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-3">Sur demande · Conciergerie</p>
        <ul class="space-y-2 text-sm text-[var(--color-bone-soft)]">
          {amenities.services_on_demand.map((s) => (
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-gold)] mt-1">·</span>
              <span>{s}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div>
      <p class="eyebrow mb-5">Équipements</p>
      <ul class="grid grid-cols-2 gap-x-6 gap-y-4 md:grid-cols-3">
        {amenities.included.map((a, i) => (
          <li class="flex items-start gap-3 border-t border-[var(--color-gold)]/15 pt-3">
            <span class="chapter-index w-6 flex-shrink-0">{String(i + 1).padStart(2, "0")}</span>
            <span class="text-sm leading-snug">{a.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Chapter>
