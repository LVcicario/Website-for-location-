---
import ChapterReveal from "./ChapterReveal";
import AmenityIcon from "./AmenityIcon.astro";
import { getCopy } from "~/content/copy";
import type { Locale } from "~/i18n/config";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const { amenities, signature } = getCopy(locale);
---

<section id="amenities" class="chapter chapter--amenities">
  <div class="chapter__inner">
    <ChapterReveal client:visible stagger as="header" className="mb-12 md:mb-16 max-w-[62ch]">
      <p data-reveal-child class="eyebrow">
        <span class="chapter-index mr-4">{amenities.index}</span>
        {amenities.eyebrow}
      </p>
      <h2 data-reveal-child class="display mt-4">{amenities.title}</h2>
      <hr data-reveal-child class="rule-gold" />
      <p data-reveal-child class="lede">{amenities.intro}</p>
    </ChapterReveal>

    <!-- Stat bar hero -->
    <ChapterReveal client:visible stagger as="div" className="stat-bar grid grid-cols-2 md:grid-cols-4 gap-y-10 md:gap-y-0 gap-x-6 border-y border-[var(--color-gold)]/25 py-10 md:py-14 mb-16 md:mb-20">
      {amenities.stat_bar.map((s, i) => (
        <div data-reveal-child class={`stat-bar__item text-center ${i > 0 ? "md:border-l border-[var(--color-gold)]/15" : ""}`}>
          <p class="font-[family-name:var(--font-display)] text-6xl md:text-7xl lg:text-8xl leading-none text-[var(--color-gold)]">{s.value}</p>
          <p class="eyebrow mt-3 text-[var(--color-bone-soft)]">{s.label}</p>
        </div>
      ))}
    </ChapterReveal>

    <!-- Equipment grid -->
    <div class="equipment mb-16 md:mb-20">
      <ChapterReveal client:visible as="p" className="eyebrow mb-6">
        {amenities.equipment_label}
      </ChapterReveal>
      <ChapterReveal client:visible stagger as="ul" className="equipment-grid grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-8 gap-y-5">
        {amenities.included.map((a) => (
          <li data-reveal-child class="equipment-item flex items-center gap-3 border-t border-[var(--color-gold)]/15 pt-4">
            <span class="equipment-item__icon text-[var(--color-gold)] flex-shrink-0" aria-hidden="true">
              <AmenityIcon name={a.icon} />
            </span>
            <span class="text-sm md:text-base leading-snug text-[var(--color-bone)]">{a.label}</span>
          </li>
        ))}
      </ChapterReveal>
    </div>

    <!-- Services: included card (single, full width) -->
    <ChapterReveal client:visible stagger as="div" className="services-cards mx-auto max-w-[var(--content-max)]">
      <div data-reveal-child class="service-card relative p-8 md:p-12 bg-[var(--color-ink-soft)] border border-[var(--color-gold)]/15">
        <p class="eyebrow text-[var(--color-bone-soft)]">Inclus</p>
        <p class="mt-1 font-[family-name:var(--font-display)] text-2xl md:text-3xl leading-tight">{amenities.services_included_label}</p>
        <hr class="rule-gold" />
        <ul class="grid gap-3 md:grid-cols-2 md:gap-x-12">
          {amenities.services_included.map((s) => (
            <li class="flex items-start gap-3 text-sm md:text-base leading-relaxed text-[var(--color-bone-soft)]">
              <span class="text-[var(--color-gold)] mt-0.5 flex-shrink-0" aria-hidden="true">·</span>
              <span>{s}</span>
            </li>
          ))}
        </ul>
      </div>
    </ChapterReveal>

    <p class="signature mt-12 text-right">{signature}</p>
  </div>
</section>

<style>
  .chapter--amenities {
    background:
      linear-gradient(180deg, var(--color-navy) 0%, var(--color-ink) 100%);
  }
  .stat-bar__item {
    position: relative;
  }
  .service-card--premium::before {
    content: "";
    position: absolute;
    inset: -1px;
    background: linear-gradient(135deg, rgba(184, 147, 90, 0.25) 0%, rgba(184, 147, 90, 0) 40%, rgba(184, 147, 90, 0.2) 100%);
    pointer-events: none;
    z-index: 0;
  }
  .service-card > * {
    position: relative;
    z-index: 1;
  }
  .equipment-item {
    transition: border-color 400ms var(--ease-gentle), color 400ms var(--ease-gentle);
  }
  .equipment-item:hover {
    border-color: var(--color-gold);
  }
</style>
