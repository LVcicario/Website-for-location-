---
import ChapterReveal from "./ChapterReveal";
import ArtOfLivingInteractive from "./ArtOfLivingInteractive";
import { getCopy } from "~/content/copy";
import type { Locale } from "~/i18n/config";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const { art_of_living, signature } = getCopy(locale);
---

<section id="art-of-living" class="chapter">
  <div class="chapter__inner">
    <ChapterReveal client:visible stagger as="header" className="mb-10 max-w-[66ch]">
      <p data-reveal-child class="eyebrow">
        <span class="chapter-index mr-4">{art_of_living.index}</span>
        {art_of_living.eyebrow}
      </p>
      <h2 data-reveal-child class="display mt-4">{art_of_living.title}</h2>
      <hr data-reveal-child class="rule-gold" />
      <p data-reveal-child class="lede">{art_of_living.intro}</p>
    </ChapterReveal>

    <ArtOfLivingInteractive
      client:visible
      pois={art_of_living.pois}
      labels={art_of_living.labels}
    />

    <p class="signature mt-12 text-right">{signature}</p>
  </div>
</section>
