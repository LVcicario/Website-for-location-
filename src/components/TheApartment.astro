---
import ChapterReveal from "./ChapterReveal";
import RoomScroller, { type RoomImage } from "./RoomScroller";
import Picture from "./Picture.astro";
import { getCopy } from "~/content/copy";
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { Locale } from "~/i18n/config";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const { the_apartment, signature } = getCopy(locale);

const roomImageKeys = [
  "building-stairs",
  "salon-window",
  "kitchen-navy",
  "primary-bedroom",
  "guest-bedroom-a",
  "terrace-view",
];

const imagesMap = import.meta.glob<{ default: ImageMetadata }>("/src/assets/images/*.jpg");

const roomImages: (RoomImage | null)[] = await Promise.all(
  roomImageKeys.map(async (key) => {
    const loader = imagesMap[`/src/assets/images/${key}.jpg`];
    if (!loader) return null;
    const mod = await loader();
    const [avif, webp, fallback] = await Promise.all([
      getImage({ src: mod.default, width: 2000, format: "avif" }),
      getImage({ src: mod.default, width: 2000, format: "webp" }),
      getImage({ src: mod.default, width: 1800, format: "jpg" }),
    ]);
    return {
      avif: avif.src,
      webp: webp.src,
      fallback: fallback.src,
      width: mod.default.width,
      height: mod.default.height,
    };
  }),
);
---

<section id="the-apartment" class="chapter chapter--tight">
  <div class="chapter__inner">
    <ChapterReveal client:visible stagger as="header" className="mb-8 max-w-[64ch]">
      <p data-reveal-child class="eyebrow">
        <span class="chapter-index mr-4">{the_apartment.index}</span>
        {the_apartment.eyebrow}
      </p>
      <h2 data-reveal-child class="display mt-4">{the_apartment.title}</h2>
      <hr data-reveal-child class="rule-gold" />
      <p data-reveal-child class="lede">{the_apartment.intro}</p>
    </ChapterReveal>
  </div>
</section>

<div class="hidden md:block">
  <RoomScroller client:visible rooms={the_apartment.rooms} images={roomImages} />
</div>

<div class="md:hidden px-[var(--gutter)] pb-8">
  <ol class="flex flex-col gap-4">
    {the_apartment.rooms.map((room, i) => (
      <li class="relative min-h-[70vh] overflow-hidden border border-[var(--color-gold)]/20 bg-[var(--color-ink)]">
        <div class="absolute inset-0">
          <Picture src={roomImageKeys[i]} alt="" sizes="100vw" />
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-ink)]/90 via-[var(--color-ink)]/20 to-transparent"></div>
        <div class="relative z-10 flex h-full flex-col justify-end p-7">
          <p class="chapter-index">{String(i + 1).padStart(2, "0")} / {String(the_apartment.rooms.length).padStart(2, "0")}</p>
          <p class="eyebrow mt-2">{room.label}</p>
          <h3 class="mt-3 font-[family-name:var(--font-display)] text-3xl font-normal leading-tight">{room.title}</h3>
          <hr class="rule-gold" />
          <p class="text-sm leading-relaxed text-[var(--color-bone-soft)]">{room.body}</p>
        </div>
      </li>
    ))}
  </ol>
</div>

<div class="px-[var(--gutter)] py-4">
  <p class="signature text-right mx-auto max-w-[var(--content-max)]">{signature}</p>
</div>
