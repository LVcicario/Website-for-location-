---
import Base from "~/layouts/Base.astro";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import Lightbox, { type LightboxImage } from "~/components/Lightbox";
import { LOCALES, type Locale } from "~/i18n/config";
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;

const galleryKeys = [
  { key: "dining-view", label: "Salle à manger · vue baie" },
  { key: "salon-view", label: "Salon" },
  { key: "salon-window", label: "Salon · vue mer" },
  { key: "salon-art", label: "Salon · détails" },
  { key: "kitchen-navy", label: "Cuisine" },
  { key: "terrace-view", label: "Terrasse" },
  { key: "primary-bedroom", label: "Chambre principale" },
  { key: "primary-bathroom", label: "Salle de bain · marbre" },
  { key: "bathroom-gold", label: "Salle de bain · laiton" },
  { key: "guest-bedroom-a", label: "Chambre d'hôtes" },
  { key: "guest-bedroom-b", label: "Chambre d'hôtes · alt" },
  { key: "guest-bedroom-c", label: "Chambre d'hôtes · prête" },
  { key: "powder-room", label: "WC" },
  { key: "dresser-mirror", label: "Détail · console" },
  { key: "building-exterior", label: "L'immeuble" },
  { key: "building-facade", label: "Façade art déco" },
  { key: "building-stairs", label: "Entrée" },
];

const imagesMap = import.meta.glob<{ default: ImageMetadata }>("/src/assets/images/*.jpg");

const items: LightboxImage[] = (
  await Promise.all(
    galleryKeys.map(async ({ key, label }) => {
      const loader = imagesMap[`/src/assets/images/${key}.jpg`];
      if (!loader) return null;
      const mod = await loader();
      const [avif, webp, fallback, tAvif, tWebp, tFallback] = await Promise.all([
        getImage({ src: mod.default, width: 2400, format: "avif" }),
        getImage({ src: mod.default, width: 2400, format: "webp" }),
        getImage({ src: mod.default, width: 2000, format: "jpg" }),
        getImage({ src: mod.default, width: 800, format: "avif" }),
        getImage({ src: mod.default, width: 800, format: "webp" }),
        getImage({ src: mod.default, width: 800, format: "jpg" }),
      ]);
      return {
        avif: avif.src,
        webp: webp.src,
        fallback: fallback.src,
        thumbAvif: tAvif.src,
        thumbWebp: tWebp.src,
        thumbFallback: tFallback.src,
        width: mod.default.width,
        height: mod.default.height,
        label,
      };
    }),
  )
).filter((x): x is LightboxImage => x !== null);
---

<Base locale={locale} title="Galerie — Villa Azur" description="Une promenade visuelle à travers l'appartement.">
  <Nav locale={locale} />
  <main id="main" class="px-[var(--gutter)] pt-36 pb-24">
    <header class="mx-auto max-w-[var(--content-max)] mb-16">
      <p class="eyebrow">Galerie</p>
      <h1 class="display mt-4">Promenade</h1>
      <hr class="rule-gold" />
      <p class="lede max-w-[44ch]">Un premier aperçu de l'appartement, en attendant le shooting pro.</p>
      <p class="mt-6 text-xs tracking-[0.22em] uppercase text-[var(--color-bone-soft)]/60">Cliquez une image · ← → pour naviguer · Esc pour fermer</p>
    </header>

    <Lightbox client:load items={items} />
  </main>
  <Footer locale={locale} />
</Base>
